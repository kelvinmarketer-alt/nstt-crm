# Cloudflare Pages — HTTP headers config
# https://developers.cloudflare.com/pages/configuration/headers/

# === Security headers cho mọi page ===
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()

# === Service Worker: KHÔNG cache, để force update mỗi lần deploy mới ===
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# === HTML pages: short cache, vì có thể đổi text/UI ===
# CHÚ Ý: chỉ match 1 trong 2 rule sau, không match cả 2 (gây duplicate header).
/pages/*.html
  Cache-Control: public, max-age=300

/index.html
  Cache-Control: public, max-age=300

# === Code (JS/CSS): luôn revalidate qua etag ===
# Trình duyệt hỏi server mỗi lần tải: file KHÔNG đổi → 304 (vài chục byte, rất nhẹ);
# file ĐÃ đổi (deploy mới) → tải bản mới NGAY, nhân viên KHÔNG phải hard-refresh tay.
/styles/*
  Cache-Control: public, max-age=0, must-revalidate

/scripts/*
  Cache-Control: public, max-age=0, must-revalidate

# Mock data + product images (3.8MB) — 7 ngày cache (rất ít đổi)
/data/*
  Cache-Control: public, max-age=604800

/assets/*
  Cache-Control: public, max-age=604800
